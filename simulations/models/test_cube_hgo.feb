<?xml version="1.0" encoding="ISO-8859-1"?>
<febio_spec version="4.0">
  <Module type="solid"/>
  <Control>
    <analysis>STATIC</analysis>
    <time_steps>1</time_steps>
    <step_size>1</step_size>
    <solver type="solid">
      <symmetric_stiffness>symmetric</symmetric_stiffness>
      <dtol>0.001</dtol>
      <etol>0.01</etol>
      <rtol>0</rtol>
      <max_refs>15</max_refs>
    </solver>
  </Control>
  <Material>
    <material id="1" name="T" type="HGO unconstrained">
      <c>0.05</c>
      <k1>0.22</k1>
    <k2>100.0</k2><kappa>0.09</kappa><k>4.76</k></material>
  </Material>
  <Mesh>
    <Nodes name="Obj">
      <node id="1">0,0,0</node>
      <node id="2">1,0,0</node>
      <node id="3">1,1,0</node>
      <node id="4">0,1,0</node>
      <node id="5">0,0,1</node>
      <node id="6">1,0,1</node>
      <node id="7">1,1,1</node>
      <node id="8">0,1,1</node>
    </Nodes>
    <Elements type="hex8" name="Body">
      <elem id="1">1,2,3,4,5,6,7,8</elem>
    </Elements>
    <NodeSet name="Fix">1,2,3,4</NodeSet>
  </Mesh>
  <MeshDomains>
    <SolidDomain name="Body" mat="T"/>
  </MeshDomains>
  <Boundary>
    <bc name="Fix" type="zero displacement" node_set="Fix">
      <x_dof>1</x_dof>
      <y_dof>1</y_dof>
      <z_dof>1</z_dof>
    </bc>
  </Boundary>
  <Output>
    <plotfile type="febio">
      <var type="displacement"/>
    </plotfile>
    <logfile>
      <node_data data="ux;uy;uz" delim="," file="cube_hgo_nodes.csv">1,2,3,4,5,6,7,8</node_data>
    </logfile>
  </Output>
</febio_spec>